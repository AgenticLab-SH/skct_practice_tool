{
  "rules": {
    ".read": false,
    ".write": false,
    "active_visitors": {
      ".read": true,
      "$sessionId": {
        ".write": "$sessionId.matches(/^sess_[A-Za-z0-9]{9,20}$/) && (!newData.exists() || (newData.isNumber() && newData.val() >= now - 86400000 && newData.val() <= now + 300000))",
        ".validate": "!newData.exists() || newData.isNumber()"
      }
    },
    "total_visits": {
      ".read": true,
      ".write": "newData.isNumber() && newData.val() >= 0 && (!data.exists() ? newData.val() <= 1 : (data.isNumber() && newData.val() >= data.val() && newData.val() <= data.val() + 1))"
    },
    "daily_visits": {
      ".read": true,
      "$dateKey": {
        ".write": "$dateKey.matches(/^\\d{4}-\\d{2}-\\d{2}$/) && newData.isNumber() && newData.val() >= 0 && (!data.exists() ? newData.val() <= 1 : (data.isNumber() && newData.val() >= data.val() && newData.val() <= data.val() + 1))"
      }
    },
    "stats": {
      "live_peak_daily": {
        ".read": true,
        "$dateKey": {
          ".write": "$dateKey.matches(/^\\d{4}-\\d{2}-\\d{2}$/) && newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000 && (!data.exists() || (data.isNumber() && newData.val() >= data.val() && newData.val() <= data.val() + 100))"
        }
      }
    },
    "config": {
      ".read": "auth != null",
      ".write": "auth != null",
      "appName": {
        ".read": true
      },
      "guideDefaults": {
        ".read": true
      },
      "layoutRatios": {
        ".read": true
      },
      "maintenance": {
        ".read": true
      },
      "manualSubscriptionConfig": {
        ".read": true
      },
      "notice": {
        ".read": true
      },
      "notice_help": {
        ".read": true
      },
      "notice_sidebar": {
        ".read": true
      },
      "notice_community": {
        ".read": true
      },
      "popularConfig": {
        ".read": true
      },
      "popupLayout": {
        ".read": true
      },
      "siteTextConfig": {
        ".read": true
      },
      "sponsors": {
        ".read": true
      },
      "supportConfig": {
        ".read": true
      },
      "timerDefaults": {
        ".read": true
      },
      "toolUiConfig": {
        ".read": true
      },
      "useful_links": {
        ".read": true
      },
      "adminHash": {
        ".read": false,
        ".write": false
      },
      "advancedFeatureConfig": {
        ".read": false,
        ".write": "auth != null"
      },
      "$key": {
        ".write": "auth != null"
      }
    },
    "subscriptionRequests": {
      ".read": "auth != null",
      "$requestId": {
        ".read": true,
        ".write": "auth != null || (!data.exists() && newData.child('requestId').val() === $requestId && newData.child('status').val() === 'pending')"
      }
    },
    "subscriptionRequestLookup": {
      ".read": false,
      "$lookupKey": {
        ".read": true,
        ".write": "auth != null || ($lookupKey.matches(/^[a-f0-9]{64}$/) && newData.hasChildren(['requestId', 'createdAt']) && newData.child('requestId').isString() && newData.child('createdAt').isNumber())"
      }
    },
    "advancedAccountLicenses": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$loginIdKey": {
        ".read": true,
        ".write": "auth != null"
      }
    },
    "userStudyLibrary": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "items": {
          "$itemId": {
            ".read": "auth != null && auth.uid === $uid",
            ".write": "auth != null && auth.uid === $uid"
          }
        }
      }
    },
    "posts": {
      ".read": true,
      "$postId": {
        ".write": "auth != null || newData.exists()",
        ".validate": "newData.hasChildren(['category', 'nickname', 'passwordHash', 'content', 'timestamp', 'likes', 'replyCount', 'deleted', 'pinned'])",
        "category": {
          ".validate": "newData.isString() && newData.val().matches(/^(qna|tip|review|improvement|faq)$/) && (!data.exists() || auth != null || newData.val() == data.val())"
        },
        "nickname": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 20 && (!data.exists() || auth != null || newData.val() == data.val())"
        },
        "passwordHash": {
          ".validate": "newData.isString() && newData.val().matches(/^[a-f0-9]{64}$/) && (!data.exists() || auth != null || newData.val() == data.val())"
        },
        "content": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 1000"
        },
        "timestamp": {
          ".validate": "newData.isNumber() && (!data.exists() || auth != null || newData.val() == data.val())"
        },
        "likes": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && (!data.exists() ? newData.val() == 0 : (auth != null || (data.isNumber() && newData.val() >= data.val() - 1 && newData.val() <= data.val() + 1)))"
        },
        "replyCount": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && (!data.exists() ? newData.val() == 0 : (auth != null || (data.isNumber() && newData.val() >= data.val() - 1 && newData.val() <= data.val() + 1)))"
        },
        "deleted": {
          ".validate": "newData.isBoolean()"
        },
        "pinned": {
          ".validate": "newData.isBoolean() && (!data.exists() ? newData.val() == false : (auth != null || newData.val() == data.val()))"
        },
        "editedAt": {
          ".validate": "!newData.exists() || newData.isNumber()"
        },
        "deletedAt": {
          ".validate": "!newData.exists() || newData.isNumber()"
        },
        "$other": {
          ".validate": false
        }
      }
    },
    "replies": {
      ".read": true,
      "$postId": {
        "$replyId": {
          ".write": "auth != null || newData.exists()",
          ".validate": "newData.hasChildren(['nickname', 'passwordHash', 'content', 'timestamp', 'isAdmin', 'pinned', 'deleted'])",
          "nickname": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 20"
          },
          "passwordHash": {
            ".validate": "newData.isString() && (auth != null ? newData.val().length <= 64 : newData.val().matches(/^[a-f0-9]{64}$/)) && (!data.exists() || auth != null || newData.val() == data.val())"
          },
          "content": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 1000"
          },
          "timestamp": {
            ".validate": "newData.isNumber() && (!data.exists() || auth != null || newData.val() == data.val())"
          },
          "isAdmin": {
            ".validate": "newData.isBoolean() && (!data.exists() ? (auth != null || newData.val() == false) : (auth != null || newData.val() == data.val()))"
          },
          "pinned": {
            ".validate": "newData.isBoolean() && (!data.exists() ? (auth != null || newData.val() == false) : (auth != null || newData.val() == data.val()))"
          },
          "deleted": {
            ".validate": "newData.isBoolean()"
          },
          "editedAt": {
            ".validate": "!newData.exists() || newData.isNumber()"
          },
          "deletedAt": {
            ".validate": "!newData.exists() || newData.isNumber()"
          },
          "$other": {
            ".validate": false
          }
        }
      }
    },
    "userLikes": {
      ".read": true,
      "$sessionId": {
        "$postId": {
          ".write": "$sessionId.matches(/^S[A-Za-z0-9]{9}$/) && (!newData.exists() || newData.val() === true)",
          ".validate": "!newData.exists() || newData.val() === true"
        }
      }
    },
    "staging_hidden_v1": {
      ".read": false,
      ".write": false,
      "active_visitors": {
        ".read": true,
        "$sessionId": {
          ".write": "$sessionId.matches(/^sess_[A-Za-z0-9]{9,20}$/) && (!newData.exists() || (newData.isNumber() && newData.val() >= now - 86400000 && newData.val() <= now + 300000))",
          ".validate": "!newData.exists() || newData.isNumber()"
        }
      },
      "total_visits": {
        ".read": true,
        ".write": "newData.isNumber() && newData.val() >= 0 && (!data.exists() ? newData.val() <= 1 : (data.isNumber() && newData.val() >= data.val() && newData.val() <= data.val() + 1))"
      },
      "daily_visits": {
        ".read": true,
        "$dateKey": {
          ".write": "$dateKey.matches(/^\\d{4}-\\d{2}-\\d{2}$/) && newData.isNumber() && newData.val() >= 0 && (!data.exists() ? newData.val() <= 1 : (data.isNumber() && newData.val() >= data.val() && newData.val() <= data.val() + 1))"
        }
      },
      "config": {
        ".read": "auth != null",
        "appName": {
          ".read": true
        },
        "guideDefaults": {
          ".read": true
        },
        "layoutRatios": {
          ".read": true
        },
        "maintenance": {
          ".read": true
        },
        "manualSubscriptionConfig": {
          ".read": true
        },
        "notice": {
          ".read": true
        },
        "notice_help": {
          ".read": true
        },
        "notice_sidebar": {
          ".read": true
        },
        "notice_community": {
          ".read": true
        },
        "popularConfig": {
          ".read": true
        },
        "popupLayout": {
          ".read": true
        },
        "siteTextConfig": {
          ".read": true
        },
        "sponsors": {
          ".read": true
        },
        "supportConfig": {
          ".read": true
        },
        "timerDefaults": {
          ".read": true
        },
        "toolUiConfig": {
          ".read": true
        },
        "useful_links": {
          ".read": true
        },
        "adminHash": {
          ".read": false,
          ".write": false
        },
        "advancedFeatureConfig": {
          ".read": false,
          ".write": "auth != null"
        },
        "$key": {
          ".write": "auth != null"
        }
      },
      "userStudyLibrary": {
        "$uid": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.uid === $uid",
          "items": {
            "$itemId": {
              ".read": "auth != null && auth.uid === $uid",
              ".write": "auth != null && auth.uid === $uid"
            }
          }
        }
      }
    }
  }
}
